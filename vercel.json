{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth/login", "dest": "/api/auth/login.js" },
    { "src": "/api/auth/me", "dest": "/api/auth/me.js" },
    { "src": "/api/webhook/hotmart", "dest": "/api/webhook/hotmart.js" },
    { "src": "/api/setup", "dest": "/api/setup.js" },
    { "src": "/api/terminal", "dest": "/api/terminal.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
